# Copy this to .env and fill in your values

# ── Database (Supabase PostgreSQL) ──
DATABASE_URL=postgresql+asyncpg://postgres.xxxxxxxxxxxx:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
DATABASE_URL_SYNC=postgresql+psycopg2://postgres.xxxxxxxxxxxx:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Auth / JWT ──
SECRET_KEY=change-this-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── S3 ──
S3_BUCKET_NAME=prometheon-docs
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Celery ──
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── App ──
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
CARRY_FORWARD_CUTOFF_HOUR=19
